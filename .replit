run =  ["gunicorn", "--bind", "0.0.0.0:5000", "run:app"]
entrypoint = "run.py"
modules = ["nodejs-20", "python-3.11", "python3", "postgresql-16"]

hidden = [".pythonlibs"]

[nix]
channel = "stable-24_05"
packages = ["cargo", "glibcLocales", "libiconv", "libxcrypt", "openssl", "pkg-config", "rustc"]

[deployment]
run = ["gunicorn", "--bind=0.0.0.0:5000", "--reuse-port", "--timeout=600", "run:app"]
deploymentTarget = "vm"
build = ["bash", "scripts/build.sh"]

[[ports]]
localPort = 5000
externalPort = 80

[objectStorage]
defaultBucketID = "replit-objstore-14f1b847-9243-4a51-b979-b86c328f7947"

[workflows]
runButton = "Project"

[[workflows.workflow]]
name = "Project"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Flask App"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Consensus Worker"

[[workflows.workflow]]
name = "Flask App"
author = "agent"

[workflows.workflow.metadata]
outputType = "webview"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "gunicorn --bind=0.0.0.0:5000 --reuse-port --timeout=600 run:app"
waitForPort = 5000

[[workflows.workflow]]
name = "Consensus Worker"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "python3 scripts/run_consensus_worker.py"

[[workflows.workflow]]
name = "Consensus Worker Pool (x3)"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "CONSENSUS_WORKER_ID=worker-1 python3 scripts/run_consensus_worker.py"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "CONSENSUS_WORKER_ID=worker-2 python3 scripts/run_consensus_worker.py"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "CONSENSUS_WORKER_ID=worker-3 python3 scripts/run_consensus_worker.py"

[[workflows.workflow]]
name = "Project (Worker Pool x3)"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Flask App"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Consensus Worker Pool (x3)"

[agent]
expertMode = true

[userenv]

[userenv.shared]
SITE_URL = "https://societyspeaks.io"
POSTHOG_HOST = "https://eu.i.posthog.com"
BRIEF_FROM_EMAIL = "hello@brief.societyspeaks.io"
APP_BASE_URL = "https://societyspeaks.io"
RESEND_FROM_EMAIL = "Society Speaks <hello@brief.societyspeaks.io>"
RESEND_DAILY_FROM_EMAIL = "Daily Questions <daily@brief.societyspeaks.io>"
AUDIO_ENABLED = "false"
STRIPE_PERSONAL_MONTHLY_PRICE_ID = "price_1T0InvAjRojnyfWfBrvh6xe8"
STRIPE_PERSONAL_YEARLY_PRICE_ID = "price_1T0IoaAjRojnyfWfKlEFMxme"
X_POSTING_ENABLED = "false"

[userenv.production]

[userenv.development]
