run =  ["gunicorn", "--bind", "0.0.0.0:5000", "run:app"]
entrypoint = "run.py"
modules = ["nodejs-20", "python-3.11", "python3", "postgresql-16"]

hidden = [".pythonlibs"]

[nix]
channel = "stable-24_05"
packages = ["cargo", "glibcLocales", "libiconv", "libxcrypt", "openssl", "pkg-config", "rustc"]

[deployment]
run = ["bash", "-c", "(while true; do APP_ROLE=scheduler python3 scripts/run_scheduler.py; echo \"Scheduler exited ($?), restarting in 5s...\"; sleep 5; done) & SCHED_PID=$!; APP_ROLE=web gunicorn run:app & WEB_PID=$!; trap 'kill $SCHED_PID $WEB_PID 2>/dev/null' INT TERM; wait $WEB_PID; EXIT_CODE=$?; kill $SCHED_PID 2>/dev/null; wait; exit $EXIT_CODE"]
deploymentTarget = "vm"
build = ["bash", "scripts/build.sh"]

[[ports]]
localPort = 5000
externalPort = 80

[objectStorage]
defaultBucketID = "replit-objstore-14f1b847-9243-4a51-b979-b86c328f7947"

[workflows]
runButton = "Project"

[[workflows.workflow]]
name = "Project"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Flask App"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Consensus Worker Pool (x3)"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Fill Translations"

[[workflows.workflow]]
name = "Flask App"
author = "agent"

[workflows.workflow.metadata]
outputType = "webview"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "APP_ROLE=web gunicorn -c gunicorn_config.py run:app"
waitForPort = 5000

[[workflows.workflow]]
name = "Consensus Worker Pool (x3)"
mode = "parallel"
author = "agent"

[workflows.workflow.metadata]
outputType = "console"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "bash -c \"APP_ROLE=worker CONSENSUS_WORKER_ID=worker-1 python3 scripts/run_consensus_worker.py & APP_ROLE=worker CONSENSUS_WORKER_ID=worker-2 python3 scripts/run_consensus_worker.py & APP_ROLE=worker CONSENSUS_WORKER_ID=worker-3 python3 scripts/run_consensus_worker.py & wait\""

[[workflows.workflow]]
name = "Project (Worker Pool x3)"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Flask App"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Consensus Worker Pool (x3)"

[[workflows.workflow]]
name = "Fill Translations"
author = "agent"

[workflows.workflow.metadata]
outputType = "console"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "python3 scripts/translate_po_with_haiku.py --batch-size 5"

[agent]
expertMode = true

[userenv]

[userenv.shared]
SITE_URL = "https://societyspeaks.io"
POSTHOG_HOST = "https://eu.i.posthog.com"
BRIEF_FROM_EMAIL = "hello@brief.societyspeaks.io"
APP_BASE_URL = "https://societyspeaks.io"
RESEND_FROM_EMAIL = "Society Speaks <hello@brief.societyspeaks.io>"
RESEND_DAILY_FROM_EMAIL = "Daily Questions <daily@brief.societyspeaks.io>"
AUDIO_ENABLED = "false"
STRIPE_PERSONAL_MONTHLY_PRICE_ID = "price_1T0InvAjRojnyfWfBrvh6xe8"
STRIPE_PERSONAL_YEARLY_PRICE_ID = "price_1T0IoaAjRojnyfWfKlEFMxme"
X_POSTING_ENABLED = "false"
GUNICORN_CMD_ARGS = "-c gunicorn_config.py"

[userenv.production]

[userenv.development]
