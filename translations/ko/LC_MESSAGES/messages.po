msgid "Choose an amount"
msgstr "금액을 선택하세요"

#: app/templates/donate.html:36
msgid "Or enter a custom amount in GBP:"
msgstr "또는 GBP로 사용자 지정 금액을 입력하세요:"

#: app/templates/donate.html:42
msgid "e.g. 12.50"
msgstr "예: 12.50"

#: app/templates/donate.html:49
msgid "Name (optional)"
msgstr "이름 (선택사항)"

