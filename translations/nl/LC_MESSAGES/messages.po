msgid ""
"<strong>Present results without attribution</strong> to Society Speaks (the "
"\"Powered by\" or link must remain visible)"
msgstr ""
"<strong>Presenteer resultaten zonder bronvermelding</strong> aan Society "
"Speaks (de 'Powered by' of link moet zichtbaar blijven)"

