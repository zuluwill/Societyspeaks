msgid ""
"<strong>Rehost</strong> the full analysis dataset or clustering results on "
"your own servers"
msgstr ""
"<strong>Herhost</strong> de volledige analysedataset of clusteringresultaten"
" op uw eigen servers"

#: app/templates/partner/rules.html:168
