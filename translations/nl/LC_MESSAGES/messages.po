msgid "🔥 Controversial"
msgstr "🔥 Controversieel"

#: app/templates/help/native_system.html:183
msgid "Most divisive statements (close to 50/50 split)"
msgstr "Meest verdeelde uitspraken (dicht bij 50/50 verdeling)"

