msgid ""
"<code class=\"text-purple-700\">POST "
"/api/partner/webhooks/{endpoint_id}/rotate-secret</code> - rotate signing "
"secret"
msgstr ""
"<code class=\"text-purple-700\">POST "
"/api/partner/webhooks/{endpoint_id}/rotate-secret</code> - rotar secreto de "
"firma"

#: app/templates/partner/api_docs.html:1037
#, python-brace-format
