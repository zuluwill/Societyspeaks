msgstr ""
"<code class=\"text-purple-700\">GET /api/partner/webhooks</code> - listar "
"endpoints de webhook"

#: app/templates/partner/api_docs.html:1034
msgid ""
"<code class=\"text-purple-700\">POST /api/partner/webhooks</code> - create "
"endpoint and receive signing secret once"
msgstr ""
"<code class=\"text-purple-700\">POST /api/partner/webhooks</code> - crear "
"endpoint y recibir secreto de firma una sola vez"

#: app/templates/partner/api_docs.html:1035
#, python-brace-format
msgid ""
"<code class=\"text-purple-700\">PATCH "
"/api/partner/webhooks/{endpoint_id}</code> - pause/resume and update event "
"subscriptions"
msgstr ""
"<code class=\"text-purple-700\">PATCH "
"/api/partner/webhooks/{endpoint_id}</code> - pausar/reanudar y actualizar "
"suscripciones de eventos"

#: app/templates/partner/api_docs.html:1036
