msgstr "10 req / min / IP"

#: app/templates/partner/api_docs.html:1258
msgid "Inline statement from embed (partner-scoped discussions)"
msgstr ""
"Déclaration insérée depuis l'intégration (discussions limitées aux "
"partenaires)"

#: app/templates/partner/api_docs.html:1259
msgid "Default 25 / reader / hour + IP ceiling; see env"
msgstr "25 par défaut / lecteur / heure + plafond IP ; voir env"

#: app/templates/partner/api_docs.html:1263
