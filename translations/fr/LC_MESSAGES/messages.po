msgstr "Quand l'analyse n'est pas prête"

#: app/templates/partner/api_docs.html:605
msgid ""
"<code>forbidden</code> - Valid test API key required for test discussions"
msgstr ""
"<code>forbidden</code> - Clé API de test valide requise pour les discussions"
" de test"

#: app/templates/partner/api_docs.html:609
msgid "<code>discussion_not_found</code> - Discussion does not exist"
msgstr "<code>discussion_not_found</code> - La discussion n'existe pas"

#: app/templates/partner/api_docs.html:624
msgid "Customize the embed appearance with URL parameters."
msgstr "Personnalisez l'apparence de l'intégration avec les paramètres d'URL."

#: app/templates/partner/api_docs.html:625
#: app/templates/partner/embed_generator.html:30
msgid "Embeds are available for Society Speaks native discussions."
msgstr ""
"Les intégrations sont disponibles pour les discussions natives de Society "
