msgstr ""
"Envoyé quand la hauteur du contenu de l'intégration change. À utiliser pour "
"redimensionner l'iframe."

#: app/templates/partner/api_docs.html:676
msgid "Example: Auto-resize iframe"
msgstr "Exemple : Redimensionnement automatique de l'iframe"

#: app/templates/partner/api_docs.html:693
