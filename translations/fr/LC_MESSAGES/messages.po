msgstr "Extrait d'article pour les énoncés générés par IA"

#: app/templates/partner/api_docs.html:889
#, python-brace-format
msgid "Array of {content, position} statements"
msgstr "Tableau d'énoncés {content, position}"

#: app/templates/partner/api_docs.html:894
