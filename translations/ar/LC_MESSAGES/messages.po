#: app/templates/index.html:371
msgid ""
"\"Access to reliable, unbiased news is essential for a functioning "
"democracy.\""
msgstr "\"الوصول إلى أخبار موثوقة وغير متحيزة ضروري لازدهار الديمقراطية.\""

#: app/templates/index.html:375
