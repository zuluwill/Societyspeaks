msgstr ""
"اختر خطة لإنشاء مفاتيح مباشرة، ثم تحقق من نطاقات الإنتاج قبل إطلاق التضمينات"
" علناً."

#: app/templates/partner/portal/getting_started.html:257
#: app/templates/partner/portal/success.html:73
msgid "Starter &mdash; &pound;49/mo"
msgstr "Starter — £49/mo"

