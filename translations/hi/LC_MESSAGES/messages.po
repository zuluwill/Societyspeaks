msgstr "एंबेड इंप्रेशन"

#: app/templates/partner/hub.html:817
msgid "Incremental revenue"
msgstr "वृद्धिशील राजस्व"

#: app/templates/partner/hub.html:818
msgid "Plan cost"
msgstr "योजना लागत"

#: app/templates/partner/hub.html:819
