"<strong>Data Controller:</strong> William Roberts Coaching and Advisory Ltd"
msgstr ""
"<strong>डेटा नियंत्रक:</strong> William Roberts Coaching and Advisory Ltd"

#: app/templates/privacy-policy.html:18
msgid "<strong>For data privacy inquiries:</strong> info@societyspeaks.io"
msgstr "<strong>डेटा गोपनीयता प्रश्नों के लिए:</strong> info@societyspeaks.io"

#: app/templates/privacy-policy.html:19
msgid "<strong>For account security:</strong> security@societyspeaks.io"
msgstr "<strong>खाता सुरक्षा के लिए:</strong> security@societyspeaks.io"

