msgstr ""
"<code class=\"text-purple-700\">GET /api/partner/webhooks</code> - webhook "
"endpoints को list करें"

#: app/templates/partner/api_docs.html:1034
msgid ""
"<code class=\"text-purple-700\">POST /api/partner/webhooks</code> - create "
"endpoint and receive signing secret once"
msgstr ""
"<code class=\"text-purple-700\">POST /api/partner/webhooks</code> - endpoint"
" create करें और signing secret एक बार receive करें"

