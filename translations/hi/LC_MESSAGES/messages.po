msgstr ""
"Society Speaks गोपनीयता नीति जो बताती है कि हम आपके व्यक्तिगत डेटा को कैसे "
"एकत्र, उपयोग, संग्रहीत और सुरक्षित करते हैं।"

#: app/templates/privacy-policy.html:10
#: app/templates/terms-and-conditions.html:10
msgid "Effective Date: November 2, 2024"
msgstr "प्रभावी तारीख: 2 नवंबर, 2024"

